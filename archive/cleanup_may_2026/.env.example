# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Wake word (stub). If set, assistant only responds when heard.
# Example: WAKE_WORD=hey computer
WAKE_WORD=

# Speech-to-text: google | sphinx | text
STT_BACKEND=google
LISTEN_TIMEOUT_S=6.0
PHRASE_TIME_LIMIT_S=10.0

# Text-to-speech
TTS_RATE=185
# Optional substring to select a specific Windows voice by name/id
TTS_VOICE_CONTAINS=

# YouTube
YOUTUBE_USE_PYTUBE=true
# If true, tries to download audio-only stream (no mp3 conversion)
YOUTUBE_DOWNLOAD_AUDIO=false
YOUTUBE_DOWNLOAD_DIR=downloads

# Logging
LOG_LEVEL=INFO
